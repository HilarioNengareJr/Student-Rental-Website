# Copy to .env and fill in. Loaded at startup via python-dotenv.

# Flask session signing key — set a long random value in production.
SECRET_KEY=change-me

# Gmail SMTP credentials for enquiry emails (Flask-Mail).
MY_EMAIL=you@gmail.com
MY_MAIL_PASSWORD=your-app-password

# Where enquiry emails are delivered.
ENQUIRY_RECIPIENT=owner@example.com

# Elasticsearch endpoint for search (optional — search falls back to
# in-memory filtering when unset or unreachable).
ELASTICSEARCH_URL=http://localhost:9200
